# ============================================================================
# Environment variables — see docs/supabase-connection.md for the full guide.
# Copy to .env.local (gitignored) and fill in real values.
#   · VITE_*            → shipped to the browser bundle; configured in Netlify.
#   · server secrets    → Netlify "Functions" scope (never VITE_).
#   · dev/admin tooling → LOCAL ONLY (.env.local). Do NOT add to Netlify.
# ============================================================================

# --- App client (browser) · also set in Netlify ---------------------------
# Supabase Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mapbox public token (browser-safe). Restrict it by URL in your Mapbox account
# (atlasrouge.com, *.atlasrouge.com, localhost). Powers the property maps.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token

# --- Netlify Functions (server-side) · set in Netlify, NOT VITE_ ----------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
# Optional lead notifications (notify-lead function); leads still save without these:
# RESEND_API_KEY=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ============================================================================
# LOCAL ONLY — dev/admin tooling. Keep in .env.local, NEVER add to Netlify.
# ============================================================================

# Supabase Personal Access Token (sbp_...) for applying SQL migrations via the
# Management API: `npm run migrate -- supabase/migrations/<file>.sql`.
# Create at supabase.com > Account > Access Tokens. The live site never applies
# migrations, so this MUST stay local. Account-wide power — treat as a secret.
SUPABASE_ACCESS_TOKEN=sbp_your-personal-access-token

# Non-VITE copies used by local scripts (sitemap, migrate, translate):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Local verification (log in as an agent to test flows from scripts):
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-password

# Local batch jobs that must bypass RLS (e.g. translating existing properties).
# Never in the browser bundle, never in Netlify.
# SUPABASE_SERVICE_ROLE_KEY=

# Local photo downloads (optional):
# PEXELS_API_KEY=
# UNSPLASH_ACCESS_KEY=
