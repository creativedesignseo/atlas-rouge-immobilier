# Supabase Configuration
# Get these values from your Supabase project: Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mapbox public token (browser-safe). Restrict it by URL in your Mapbox account
# (atlasrouge.com, *.atlasrouge.com, localhost). Powers the property maps.
VITE_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Server-side only. Configure this in Netlify environment variables.
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
